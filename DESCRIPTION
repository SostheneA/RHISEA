Package: RHISEA
Type: Package
Title: RHISEA: Modern Mixed-Stock Analysis with Flexible Classifiers
Version: 0.1.0
Authors@R: 
    c(person("Sosthene", "A. V. Akia", 
             email = "sosthene.akia@dfo-mpo.gc.ca", 
             role = c("aut", "cre", "cph"),
